    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst totalSent = items.length;\nconst emails = items.filter(item => \n  item.json['Outreach Method'] === 'Email'\n).length;\nconst linkedIn = items.filter(item => \n  item.json['Outreach Method'] === 'LinkedIn DM'\n).length;\n\nconst companies = items\n  .map(item => item.json['Company'])\n  .filter(Boolean)\n  .join('\\n');\n\nconst report = `\n📊 The Scout — Daily Report\n📅 Date: ${new Date().toDateString()}\n\n✅ Total HRs Contacted: ${totalSent}\n📧 Emails Sent: ${emails}\n💬 LinkedIn DMs: ${linkedIn}\n\n🏢 Companies Contacted:\n${companies}\n`;\n\nreturn { report };"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
