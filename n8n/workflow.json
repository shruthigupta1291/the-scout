    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst content = response.choices[0].message.content;\n\n// Clean up response and parse JSON\nconst cleaned = content.replace(/```json|```/g, '').trim();\nconst contact = JSON.parse(cleaned);\n\nreturn {\n  email: contact.email || null,\n  apply_link: contact.apply_link || null,\n  poster_name: contact.poster_name || null,\n  poster_linkedin: contact.poster_linkedin || null,\n  job_title: $('Split Jobs').first().json.job_title,\n  company: $('Split Jobs').first().json.employer_name,\n  job_url: $('Split Jobs').first().json.job_apply_link\n};"
      },
