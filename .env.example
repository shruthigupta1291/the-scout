# ==========================================
# THE SCOUT — Environment Variables
# ==========================================
# Copy this file to .env and fill in values
# Never commit .env to GitHub!
# ==========================================

# ---- JSearch API (RapidAPI) ----
# Get from: rapidapi.com → JSearch → Subscribe (free)
JSEARCH_API_KEY=your_rapidapi_key_here

# ---- Groq API ----
# Get from: console.groq.com → API Keys → Create
GROQ_API_KEY=your_groq_api_key_here

# ---- Google OAuth (for Gmail + Sheets) ----
# Get from: console.cloud.google.com → The Scout project → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ---- Google Sheets ----
# The ID from your Google Sheet URL
# https://docs.google.com/spreadsheets/d/SHEET_ID/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# ---- Twilio WhatsApp ----
# Get from: twilio.com → Console → Account SID + Auth Token
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+91YOURNUMBER

# ---- Your Details ----
YOUR_NAME=Shruthi
YOUR_EMAIL=your_email@gmail.com
TARGET_ROLE=Product Manager
TARGET_LOCATION=Bangalore
